{
  "name": "gimmy",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "dotenv": "^17.2.2",
      "zod": "^4.1.13",
      "typescript": "^5",
      "convex": "^1.32.0",
      "better-auth": "1.5.5",
      "@better-auth/expo": "1.5.5",
      "@convex-dev/better-auth": "^0.11.1"
    }
  },
  "type": "module",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "check-types": "turbo check-types",
    "dev:native": "turbo -F native dev",
    "dev:web": "turbo -F web dev",
    "dev:server": "turbo -F @gimmy/backend dev",
    "dev:setup": "turbo -F @gimmy/backend dev:setup",
    "check": "ultracite check",
    "fix": "ultracite fix"
  },
  "dependencies": {
    "@gimmy/env": "workspace:*",
    "dotenv": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.6",
    "@gimmy/config": "workspace:*",
    "lefthook": "^2.1.4",
    "turbo": "^2.8.16",
    "typescript": "catalog:",
    "ultracite": "7.2.5"
  },
  "packageManager": "bun@1.3.8"
}
